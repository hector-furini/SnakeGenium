# D. ANNOTATE SIGNIFICANT UNITIGS
rule annotate_mapped_unitigs:
    input:
        bam = f"{config["gwas_pyseer"]}/unitigs_results/{{antibiotic}}_mapped_unitigs.bam",
        gff = ref_gff 
    output: 
        annotated = f"{config["gwas_pyseer"]}/unitigs_results/{{antibiotic}}_annotated_genes.tsv"
    conda: 
        config["conda_pyseer"] 
    shell:
        """
        # Check if BAM file actually has contents 
        if [ -s {input.bam} ]; then

            # Safely count only the mapped reads (-F 4 ignores unmapped reads)
            mapped_count=$(samtools view -c -F 4 {input.bam})
            
            # If the count is greater than 0, proceed with annotation
            if [ "$mapped_count" -gt 0 ]; then
                sed '/^##FASTA/,$d' {input.gff} | bedtools intersect -a stdin -b {input.bam} -wa -wb > {output.annotated}
            else
                touch {output.annotated} 
            fi
        else
            # If BAM file was 0 bytes
            touch {output.annotated}
        fi
        """
