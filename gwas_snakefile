rule map_unitigs_to_ref:
    input:
        fasta = f"{config["gwas_pyseer"]}/unitigs_results/{{antibiotic}}_sig_unitigs.fasta",
        ref = ref_genome,
        # bwa me uses indexing file in ref_genome directory
        idx = f"{ref_genome}.bwt"
    output:
        bam = f"{config["gwas_pyseer"]}/unitigs_results/{{antibiotic}}_mapped_unitigs.bam"
    conda:
        config["conda_pyseer"]
    threads: max_threads
    shell:
        """
        # Check for empty file
        if [ ! -s {input.fasta} ]; then
            touch {output.bam}
        else
            bwa mem -t {threads} {input.ref} {input.fasta} | \
            samtools view -Sb - | samtools sort -o {output.bam} -
        fi
        """
