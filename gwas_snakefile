        pattern = f"{config["gwas_pyseer"]}/unitigs_results/{{antibiotic}}",
        out_dir = f"{config["gwas_pyseer"]}/unitigs_results/"
    threads: max_threads
    conda: 
        config["conda_pyseer"]
    shell:
        """
        mkdir -p {params.out_dir};
        pyseer \
        --lmm \
        --phenotypes {input.pheno} \
        --kmers {input.unitigs} \
        --similarity {input.kinship} \
        --output-patterns {params.pattern}.patterns \
        --min-af 0.01 \
        --max-af 0.99 \
        --cpu {threads} > {output.results};
        """
