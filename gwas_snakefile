# A. RUN SNIPPY WITH REFERENCE GENOME
rule run_snippy:
    input:
        ref = ref_genome,
        contigs = f"{config["prokka_out"]}/{{gid}}/{{gid}}.fna"
    output:
        vcf = f"{config["gwas_snippy"]}/data/{{gid}}/snps.vcf"
    params:
        out_dir = f"{config["gwas_snippy"]}/data/{{gid}}"
    threads: max_threads
    conda: config["conda_snippy"]
    shell:
        """
        snippy \
        --force \
        --cpus {threads} \
        --outdir {params.out_dir} \
        --ref {input.ref} \
        --ctgs {input.contigs};
        """
