rule run_snippy_core:
    input:
        ref = ref_genome,
        vcfs = expand(f"{config["gwas_snippy"]}/data/{{gid}}/snps.vcf", gid=genome_ids)
    output:
        aln = f"{config["gwas_snippy"]}/core.full.aln",
        vcf = f"{config["gwas_snippy"]}/core.vcf.gz"
    params:
