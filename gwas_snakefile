    params:
        out_dir = f"{config["gwas_unitig"]}/unitigs",
    threads: max_threads
    conda: config["conda_unitig"]
    shell:
        """
        unitig-caller \
        --call \
        --reads {input.fasta_list} \
        --out {params.out_dir} \
        --threads {threads} \
        --pyseer &&
        # Pyseer uses a compressed unitigs file, so we compress it here
        if [ -f {params.out_dir}.pyseer ]; then
            gzip -cv {params.out_dir}.pyseer > {output.unitigs};
            rm -v {params.out_dir}.pyseer
        fi
        """
