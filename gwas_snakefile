# E. EXTRACT SNPS POSITIONS
rule extract_sig_snps_bed:
    input:
        significant = f"{config['gwas_pyseer']}/snps_results/{{antibiotic}}_snp_significant.tsv"
    output:
        bed = f"{config['gwas_pyseer']}/snps_results/{{antibiotic}}_sig_snps.bed"
    run:
        import pandas as pd
        df = pd.read_csv(input.significant, sep="\t")
        if "variant" in df.columns and not df.empty: # Ensures columns and not empty df
            with open(output.bed, "w") as f:
                for var in df["variant"]:
                    parts = str(var).rsplit("_", 3)
                    if len(parts) == 4:
                        chrom, pos_str = parts[0], parts[1] # Gets chrom and position
                        try:
                            pos = int(pos_str) # pos need to be a int to be used to locate the gene
                            f.write(f"{chrom}\t{pos-1}\t{pos}\t{var}\n")
                        except ValueError as e: # If str cannot be parsed to int
                            print(e)
                            pass
        else:
            open(output.bed, "a").close() # Writes empty file

